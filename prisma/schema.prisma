generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id       String  @id
  name     String
  location String?
  groupId  String?

  machines         Machine[]
  machineInstances MachineInstance[]
  users            User[]
  purchases        Purchase[]
  reorderRequests  ReorderRequest[]
  notifications    NotificationLogEntry[]
  auditItems       AuditItem[]
  sparePartStocks  SparePartStock[]
  defectLogs       DefectLog[]
}

model Machine {
  id             String   @id
  name           String
  model          String
  brand          String   @default("Jack")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  productLine    String
  category       String?
  imageUrl       String?
  images         String[]
  description    String?

  instances MachineInstance[]
  tickets   Ticket[]
  purchases Purchase[]
  reorders  ReorderRequest[]
}

model NeedleProduct {
  id          String  @id
  name        String
  system      String
  brand       String
  imageUrl    String
  description String?

  purchases Purchase[]
  reorders  ReorderRequest[]
}

model MachineInstance {
  id             String   @id
  serialNumber   String   @unique
  // null machineId = equipment of another brand the customer registered
  // themselves, not part of FM's catalog — brand/customName/category carry
  // its identity instead.
  machineId      String?
  machine        Machine? @relation(fields: [machineId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  location       String?
  brand          String?
  customName     String?
  category       String?

  // Maintenance tracking — applies to any machine, FM catalog or otherwise.
  lastServicedAt        DateTime?
  serviceIntervalMonths Int?
  warrantyExpiresAt     DateTime?
}

model User {
  id             String  @id
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String
  aiCredits      Int
  phone          String?

  tickets         Ticket[]
  reorderRequests ReorderRequest[]
}

model InternalAccount {
  id        String   @id
  accountId String   @unique
  password  String
  name      String
  avatarUrl String?
  skills    String[] @default([])
  // Role *is* the designation — one person can hold several (e.g.
  // "Technician" + "Marketing"), picked from a curated list or typed in
  // manually. "Admin"/"Manager" (case-insensitive) among these grant the
  // matching permission level — see canManageTasks()/isAdmin() below.
  roles String[] @default([])

  assignments TaskAssignment[]
}

model SparePart {
  id             String  @id
  name           String
  compatibleWith String
  imageUrl       String?
  description    String?

  purchases Purchase[]
  reorders  ReorderRequest[]
  stocks    SparePartStock[]
}

model Purchase {
  id              String         @id
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  itemType        String
  itemName        String
  machineId       String?
  machine         Machine?       @relation(fields: [machineId], references: [id])
  needleProductId String?
  needleProduct   NeedleProduct? @relation(fields: [needleProductId], references: [id])
  sparePartId     String?
  sparePart       SparePart?     @relation(fields: [sparePartId], references: [id])
  serialNumber    String?
  quantity        Int
  unitPrice       Float
  purchaseDate    String
}

model Ticket {
  id              String   @id
  // null machineId = the issue is on equipment of another brand the
  // customer registered themselves — customBrand/customMachineName carry
  // its identity instead (see MachineInstance).
  machineId       String?
  machine         Machine? @relation(fields: [machineId], references: [id])
  customBrand       String?
  customMachineName String?
  serialNumber    String?
  createdByUserId String
  createdBy       User     @relation(fields: [createdByUserId], references: [id])
  issueType       String
  description     String

  aiSuggestionText        String?
  aiSuggestionFromCache   Boolean?
  aiSuggestionCreditsUsed Int?

  status          String
  technicianId    String?
  technicianNotes String[]
  createdAt       DateTime @default(now())

  events      TicketEvent[]
  attachments TicketAttachment[]
}

model TicketEvent {
  id          String   @id
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type        String
  description String
  authorName  String?
  createdAt   DateTime
}

model TicketAttachment {
  id         String   @id
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  kind       String
  url        String
  uploadedAt DateTime
}

model ReorderRequest {
  id                String         @id
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id])
  requestedByUserId String
  requestedBy       User           @relation(fields: [requestedByUserId], references: [id])
  itemType          String
  itemName          String
  needleProductId   String?
  needleProduct     NeedleProduct? @relation(fields: [needleProductId], references: [id])
  sparePartId       String?
  sparePart         SparePart?     @relation(fields: [sparePartId], references: [id])
  machineId         String?
  machine           Machine?       @relation(fields: [machineId], references: [id])
  serialNumber      String?
  quantity          Int
  status            String
  createdAt         DateTime       @default(now())
}

model NotificationLogEntry {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  toPhone        String?
  channel        String
  message        String
  status         String
  createdAt      DateTime     @default(now())
}

model InternalTask {
  id                 String   @id
  title              String
  description        String?
  column             String
  priority           String
  dueDate            String?
  createdByAccountId String
  relatedTicketId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  events      TaskEvent[]
  comments    TaskComment[]
  assignments TaskAssignment[]
}

// A task can have one LEAD (owns it, like a striker who scores) and any
// number of ASSIST helpers (like a teammate who sets up the goal) — both
// roles count toward the assignee's stats, just differently (see the
// leaderboard's goals-vs-assists split in src/routes/dashboard.ts).
model TaskAssignment {
  id        String       @id
  taskId    String
  task      InternalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  accountId String
  account   InternalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role      String

  @@unique([taskId, accountId])
}

model TaskEvent {
  id              String       @id
  taskId          String
  task            InternalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type            String
  description     String
  authorAccountId String
  authorName      String
  createdAt       DateTime
}

model TaskComment {
  id              String       @id
  taskId          String
  task            InternalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorAccountId String
  authorName      String
  text            String
  createdAt       DateTime
}

model InternalNotification {
  id                   String   @id
  message              String
  taskId               String
  triggeredByAccountId String
  triggeredByName      String
  // null = broadcast to managers/admins (e.g. "a technician moved a task");
  // set = aimed at one person (e.g. "you were assigned this task").
  recipientAccountId   String?
  read                 Boolean  @default(false)
  createdAt            DateTime @default(now())
}

// A browser/device registered for Web Push. One account can have several
// (phone + laptop, etc.) — each gets pushed to independently.
model PushSubscription {
  id        String   @id
  accountId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model GarmentRecommendation {
  id               String @id
  garment          String @unique
  name             String
  description      String
  machineIds       String[]
  needleProductIds String[]

  processes GarmentProcess[]
}

model GarmentProcess {
  id               String                @id
  recommendationId String
  recommendation   GarmentRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  order            Int
  name             String
  description      String
  machineIds       String[]
  needleProductIds String[]
}

// Team targets shown as progress bars on the internal "Team Hub" page
// (e.g. a quarterly sales target, tickets-resolved goal) — set by
// managers/admins, visible to everyone as a shared sense of direction.
model TeamGoal {
  id           String   @id
  title        String
  description  String?
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Editorial cards staff write (text + an uploaded image) that surface on the
// customer portal homepage as an Apple App-Store-style featured carousel.
model ContentCard {
  id                 String   @id
  title              String
  subtitle           String?
  body               String?
  imageUrl           String
  // Extra images beyond the cover (imageUrl) — together they form the
  // swipeable "story" gallery shown when a customer opens the card.
  images             String[] @default([])
  published          Boolean  @default(true)
  order              Int      @default(0)
  createdByAccountId String
  createdByName      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Uploaded images/videos (avatars, content card photos, ticket attachments)
// are stored as bytes in the database, not on local disk — Render's free
// web service filesystem is ephemeral and gets wiped on every redeploy.
model UploadedFile {
  id        String   @id
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())
}

model CachedAnswer {
  key       String   @id
  issueType String
  text      String
  createdAt DateTime @default(now())
}

// One row per checklist question per organisation.
// Seeded automatically on first visit; auto-filled items are re-evaluated on load.
model AuditItem {
  id             String   @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  category       String
  question       String
  status         String   @default("NOT_DONE") // NOT_DONE | IN_PROGRESS | DONE | NA
  notes          String?
  documentUrl    String?
  autoFilled     Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

// Spare-parts stock the factory keeps on-site.
model SparePartStock {
  id             String    @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  sparePartId    String?
  sparePart      SparePart? @relation(fields: [sparePartId], references: [id])
  quantity       Int       @default(0)
  minThreshold   Int       @default(2)
  unit           String    @default("pcs")
  updatedAt      DateTime  @updatedAt
}

// End-of-shift quality defect entries linked to a machine serial number.
model DefectLog {
  id              String   @id
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  serialNumber    String?
  machineName     String?
  defectType      String   // SKIP_STITCH | BROKEN_STITCH | NEEDLE_HOLE | PUCKERING | TENSION | OTHER
  count           Int
  shift           String   // MORNING | EVENING | NIGHT
  loggedAt        DateTime @default(now())
  loggedByUserId  String?
}
